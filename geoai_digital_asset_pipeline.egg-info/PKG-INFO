│   │   └── data_validator.py     # Data validation
│   ├── ml/                       # Machine learning
│   │   ├── classifier.py         # Spatial classification
│   │   ├── object_detection.py   # Object detection
│   │   ├── segmentation.py       # Semantic segmentation
│   │   ├── change_detection.py   # Change detection
│   │   └── clustering.py         # Spatial clustering
│   ├── pipeline/                 # Digital asset pipeline
│   │   ├── feature_extractor.py  # Feature extraction
│   │   ├── asset_manager.py      # Asset management
│   │   └── quality_assurance.py  # Quality assurance
│   ├── workflow/                 # Processing workflows
│   │   ├── processing_graph.py   # Graph-based processing
│   │   ├── logger.py             # Logging
│   │   └── progress_tracker.py   # Progress tracking
│   └── utils/                    # Utilities
│       └── config.py             # Configuration
├── scripts/                      # Scripts
│   ├── cli.py                    # Command-line interface
│   └── use_cases.py              # Sample use cases
├── tests/                        # Unit tests
├── notebooks/                    # Jupyter notebooks
├── docs/                         # Documentation
├── models/                       # ML model files
├── data/                         # Data directory
│   ├── raw/                      # Raw input data
│   └── processed/                # Processed data
├── outputs/                      # Output results
├── config.yaml                   # Configuration file
├── requirements.txt              # Python dependencies
└── README.md                     # This file
```

## 🔧 Configuration

Edit `config.yaml` to customize pipeline behavior:

```yaml
# Project settings
project:
  name: "GeoAI Digital Asset Pipeline"
  crs_default: "EPSG:4326"

# ML settings
ml:
  classification:
    algorithm: "random_forest"
    n_estimators: 100
  object_detection:
    model: "faster_rcnn"
    confidence_threshold: 0.7
  segmentation:
    model: "unet"
    input_size: [512, 512]

# Pipeline settings
pipeline:
  feature_extraction:
    enabled_features:
      - "spectral_indices"
      - "texture_features"
  quality_assurance:
    enabled: true
    auto_repair: true
```

